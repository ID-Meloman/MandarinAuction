<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MandarinAuction</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MandarinAuction.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-custom mb-4">
            <div class="container">
                <a class="navbar-brand" href="/">Мандариновый аукцион</a>
                <div class="ms-auto">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="navbar-text me-3">
                            @User.Identity.Name
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm">Выйти</button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-sm me-2">Вход</a>
                        <a href="/Account/Register" class="btn btn-sm">Регистрация</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MandarinAuction - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
