@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow border-0">
        <div class="card-header" style="background: linear-gradient(135deg, #ff6b00 0%, #ff8c00 100%);">
            <h3 class="mb-0 text-white text-center">Вход</h3>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn w-100 text-white" style="background: linear-gradient(135deg, #ff6b00 0%, #ff8c00 100%);">
                    Войти
                </button>
            </form>
            <div class="mt-3 text-center">
                <a href="/Account/Register" style="color: #ff6b00;">Нет аккаунта? Зарегистрироваться</a>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #ff8c00;
        box-shadow: 0 0 0 0.2rem rgba(255, 107, 0, 0.25);
    }
</style>
</div>
</div>